# 실제 값을 채우려면 이 파일을 .env로 복사한 뒤 사용한다.
# .env 는 .gitignore 로 추적이 막혀 있으므로 절대 커밋되지 않아야 한다.

# ─────────────────────────────────────────────
# 실행 환경 (paper = 모의투자, live = 실전)
# Phase 0 ~ Phase 3 까지는 반드시 paper 로 둔다.
# ─────────────────────────────────────────────
KIS_ENV=paper

# ─────────────────────────────────────────────
# 한국투자증권 KIS Developers
# - HTS_ID: 한투증권 HTS/MTS 로그인 아이디
# - APP_KEY: 36자, KIS Developers 모의투자 발급분
# - APP_SECRET: 180자, KIS Developers 모의투자 발급분
# - ACCOUNT_NO: 모의 계좌번호 "XXXXXXXX-XX" (8자리-상품코드2자리)
# ─────────────────────────────────────────────
KIS_HTS_ID=
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# ─────────────────────────────────────────────
# Telegram 알림
# - BOT_TOKEN: @BotFather 가 발급한 HTTP API 토큰
# - CHAT_ID: getUpdates 로 확인한 본인 채팅 id (정수)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
